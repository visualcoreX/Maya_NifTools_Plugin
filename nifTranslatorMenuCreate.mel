global proc nifTranslatorSetInterpolator(string $type) {
	string $selection[] = `ls -selection -type "joint" -type "shape"`;

	for($i = 0;$i < size($selection); $i++) {
		int $hasAttr = 0;
		string $attributes[] = `listAttr -shortNames $selection[$i]`;

		for($j = 0;$j < size($attributes); $j++) {
			if($attributes[$j] == "interpolatorType") {
				$hasAttr = 1;
				break; 
			}
		}

		if($hasAttr == 0) { 
			eval("addAttr -dataType \"string\" -shortName \"interpolatorType\" " + $selection[$i]);	
		}
		eval("setAttr -type \"string\" " + $selection[$i] + "\.interpolatorType" + " " + $type);

		// For NiFloatInterpolator, add the "targetID" string attribute. If exactly
		// one node is selected, also pop the picker right away for convenience;
		// for multi-selection we just create the attr (a single picked ID almost
		// never applies to several different nodes) and leave it to be filled via
		// "Specify Target ID..." or by hand.
		if($type == "NiFloatInterpolator") {
			int $hasTargetID = 0;
			string $attrs2[] = `listAttr -shortNames $selection[$i]`;
			for($k = 0; $k < size($attrs2); $k++) {
				if($attrs2[$k] == "targetID") {
					$hasTargetID = 1;
					break;
				}
			}
			if($hasTargetID == 0) {
				eval("addAttr -dataType \"string\" -shortName \"targetID\" -longName \"targetID\" " + $selection[$i]);
			}

			// Only auto-open the picker for a single node, and only if there are
			// blendShape targets to pick from (otherwise just leave the empty attr).
			if(size($selection) == 1 && size(`ls -type "blendShape"`) > 0) {
				nifTranslatorSpecifyTargetIDFor($selection[$i]);
			}
		}
	}

	if(size($selection) == 0) {
		error "Must select at least one joint or shape";
	}
}

global proc nifTranslatorSetAnimationPriority() {
	string $selection[] = `ls -selection -type "joint" -type "shape"`;

	for($i = 0;$i < size($selection); $i++) {
