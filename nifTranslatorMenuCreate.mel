global proc nifTranslatorConnectNifDismemberPartitionToList(string $nifDismemberNode, string $nodes[]) {
	string $blindDataNode = "";
	string $shapeNode = "";

	for($i = 0; $i < size($nodes); $i++) {
		if(`objectType -isType "mesh" $nodes[$i]` == true) {
			$shapeNode = $nodes[$i];
		} else if(`objectType -isAType "polyBlindData" $nodes[$i]` == true) {
			$blindDataNode = $nodes[$i];
		}
	}

	if($shapeNode == "" || $blindDataNode == "") {
		if($shapeNode == "") {
			for($i = 0; $i < size($nodes); $i++) {
					if(`objectType -isType "transform" $nodes[$i]` == true) {
						string $relatives[] = `listRelatives -shapes -fullPath $nodes[$i]`;
						if(size($relatives) > 0) {
						    
							for ($x = 0; $x < size($relatives); $x++) {
								string $shadingGroups[] = `listConnections -type shadingEngine  $relatives[$x]`;

								if (size($shadingGroups) > 0) {
									$shapeNode = $relatives[$x];
									break;
								}
							}
						}
					}
				}
			}
		}

		if($shapeNode != "" && $blindDataNode == "") {
			string $current_nodes[];
			$current_nodes[0] = $shapeNode;
			do {
				$current_nodes = `listConnections -destination false -source true -plugs false -type "polyBlindData" $current_nodes[0]`;
				if(size($current_nodes) > 0) {
					string $current_partitions[] = `listConnections -destination true -source false -plugs false -type "nifDismemberPartition" $current_nodes[0]`;
					if(size($current_partitions) == 0) {
						$blindDataNode = $current_nodes[0];
					}
				} else {
					break;
				}
			} while($blindDataNode == ""); 
		} 
	

	if($shapeNode != "" && $blindDataNode != "") {
		eval("connectAttr -force " + $blindDataNode + "\.message " + $nifDismemberNode + "\.targetFaces");
		eval("connectAttr -force " + $shapeNode + "\.message " + $nifDismemberNode + "\.targetShape");
	}  else {
		print "\nPlease select an unconnected nifDismemberPartition and a shape, or a shape, an unconnected nifDismemberPartition and a polyBlindData"; 
	}
}



global proc nifTranslatorConnectBSLightningShaderToList(string $bsLightningShaderNode, string $nodes[]) {
	string $shaderNode = "";
	string $shapeNode = "";

	for($i = 0; $i < size($nodes); $i++) {
		if(`objectType -isType "mesh" $nodes[$i]` == true) {
			$shapeNode = $nodes[$i];
		} else if(`objectType -isAType "lambert" $nodes[$i]` == true) {
			$shaderNode = $nodes[$i];
		}
	}

	print "\nShader node:";
	print $shaderNode;

	print "\nShape node:";
	print $shapeNode;

	if($shapeNode == "" || $shaderNode == "") {
		if($shapeNode == "") {
			for($i = 0; $i < size($nodes); $i++) {
					if(`objectType -isType "transform" $nodes[$i]` == true) {
						string $relatives[] = `listRelatives -shapes -fullPath $nodes[$i]`;
						if(size($relatives) > 0) {
						    
							for ($x = 0; $x < size($relatives); $x++) {
								string $shadingGroups[] = `listConnections -type shadingEngine  $relatives[$x]`;

									print "\nShading groups:";
									print $shadingGroups;

								if (size($shadingGroups) > 0) {
									$shapeNode = $relatives[$x];
									break;
								}
							}
						}
					}
				}
			}
		}

		if($shapeNode != "" && $shaderNode == "") {
			string $shadingGroups[] = `listConnections -type shadingEngine  $shapeNode`;

			print "\nShading groups asddasd:";
			print $shadingGroups;

			for ($z = 0; $z < size($shadingGroups); $z++) {

				string $surfaceShader[] = `listConnections ($shadingGroups[$z] + ".surfaceShader")`;
				if (size($surfaceShader) > 0) {
					string $current_bs_shaders[] = `listConnections -destination true -source false -plugs false -type "bsLightningShader" $surfaceShader[0]`;
					if(size($current_bs_shaders) == 0) {
						$shaderNode = $surfaceShader[0];
					}
				}
			}
		} 
	

	if($shapeNode != "" && $shaderNode != "") {
		eval("connectAttr -force " + $shapeNode + "\.message " + $bsLightningShaderNode + "\.targetShape");
		eval("connectAttr -force " + $shaderNode + "\.message " + $bsLightningShaderNode + "\.targetShader");
	}  else {
		print "\nPlease select an unconnected bsLightningShader and a shape, or a shape and unconnected shader"; 
	}
}



global proc nifTranslatorConnectBSLightningShader() {
	string $bsLightningShaderNodes[] = `ls -type "bsLightningShader" -selection`;
	string $nodes[] = `ls -type "shape" -type "transform" -selection`;

	if(size($bsLightningShaderNodes) == 0) {
		print "Please select at least a bs Lightning Shader";
	}

	for($i = 0; $i < size($bsLightningShaderNodes); $i++) {
		nifTranslatorConnectNifDismemberPartitionToList($bsLightningShaderNodes[$i], $nodes);
	}
}



global proc nifTranslatorConnectNifDismemberPartition() {
	string $nifDismemberNodes[] = `ls -type "nifDismemberPartition" -selection`;
	string $nodes[] = `ls -type "shape" -type "transform" -type "polyBlindData" -selection`;

	if(size($nifDismemberNodes) == 0) {
		print "Please select at least a dismember partition";
	}

	for($i = 0; $i < size($nifDismemberNodes); $i++) {
		nifTranslatorConnectNifDismemberPartitionToList($nifDismemberNodes[$i], $nodes);
	}
}



global proc nifTranslatorCreateConnecNifDismemberPartition() {
	string $nifDismemberNode;
	string $nodes[] = `ls -type "mesh" -type "transform" -selection`;

	string $selection[] = `ls -selection`;

	$nifDismemberNode = `createNode "nifDismemberPartition"`;

	if(size($nodes) == 0) {
		print "\nPlease select at least a shape node";
	}
	nifTranslatorConnectNifDismemberPartitionToList($nifDismemberNode, $nodes);
	select -clear;

	for($i = 0; $i < size($selection); $i++) {
		select -add $selection[$i];
	}
}



global proc nifTranslatorCreateConnecBSLightningShader() {
	string $bsLightningShaderNode;
	string $nodes[] = `ls -type "mesh" -type "lambert" -type "transform" -selection`;

	string $selection[] = `ls -selection`;

	$bsLightningShaderNode = `createNode "bsLightningShader"`;

	if(size($nodes) == 0) {
		print "\nPlease select at least a shape node";
	}
	nifTranslatorConnectBSLightningShaderToList($bsLightningShaderNode, $nodes);
	select -clear;

	for($i = 0; $i < size($selection); $i++) {
		select -add $selection[$i];
	}
}




