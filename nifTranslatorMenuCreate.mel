	}
}

global proc nifTranslatorSetFNVMaterialQuick() {
    string $selection[] = `ls -selection`;
    string $shaders[];

    for($i = 0; $i < size($selection); $i++) {
        string $current = $selection[$i];
        if(`objectType -isAType "lambert" $current` == false) {
            string $current_shaders[] = nifTranslatorGetConnectedShaders($current);
            for($j = 0; $j < size($current_shaders); $j++) {
                $shaders[size($shaders)] = $current_shaders[$j];
            }
        } else {
            $shaders[size($shaders)] = $current;
        }
    }

    for($i = 0; $i < size($shaders); $i++) {
        string $current = $shaders[$i];
        string $attributes[] = `listAttr -shortNames $current`;

        // Äîáŕâë˙ĺě fnvShaderType
        int $has_type = 0;
        for($j = 0; $j < size($attributes); $j++) {
            if($attributes[$j] == "fnvShaderType") { $has_type = 1; break; }
        }
        if($has_type == 0) {
            eval("addAttr -dataType \"string\" -shortName fnvShaderType " + $current);
        }
        eval("setAttr -type \"string\" " + $current + ".fnvShaderType \"SHADER_DEFAULT\"");

        // Ńáđŕńűâŕĺě fnvShaderFlags č âűńňŕâë˙ĺě äĺôîëňíűé íŕáîđ
        int $has_flags = 0;
        for($j = 0; $j < size($attributes); $j++) {
            if($attributes[$j] == "fnvShaderFlags") { $has_flags = 1; break; }
        }
        if($has_flags == 0) {
            eval("addAttr -dataType \"string\" -shortName fnvShaderFlags " + $current);
        }
        eval("setAttr -type \"string\" " + $current + ".fnvShaderFlags \"SF_SPECULAR|SF_REMAPPABLE_TEXTURES|SF_ZBUFFER_TEST\"");
    }
}

