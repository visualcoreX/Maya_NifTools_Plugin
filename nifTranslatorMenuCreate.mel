		if($hasAttr == 0) { 
			eval("addAttr -at byte -shortName \"animationPriority\" " + $selection[$i]);
		}
		eval("setAttr " + $selection[$i] + "\.animationPriority" + " " + 30);
	}

	if(size($selection) == 0) {
		error "Must select at least one joint or shape";
	}
}

