				menuItem -label "Create and Connect bsLightningShader Node" -command "nifTranslatorCreateConnecBSLightningShader";
			setParent -menu shadingMenu;
		setParent -menu $nifToolsMenu;

		menuItem -label "Materials" -subMenu true materialsMenu;
		
			menuItem -label "Skyrim default shader quick setup" -command "nifTranslatorSetSkyrimMaterialQuick()";

			menuItem -label "Skyrim environment map shader quick setup" -command "nifTranslatorSetSkyrimEnvMapMaterialQuick()";

			menuItem -label "Skyrim shader type" -subMenu true skyrimShaderTypeMenu;
