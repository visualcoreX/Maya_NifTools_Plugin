    for($i = 0; $i < size($selection); $i++) {
        string $current = $selection[$i];
        if(`objectType -isAType "lambert" $current` == false) {
            string $current_shaders[] = nifTranslatorGetConnectedShaders($current);
            for($j = 0; $j < size($current_shaders); $j++) {
                $shaders[size($shaders)] = $current_shaders[$j];
            }
        } else {
            $shaders[size($shaders)] = $current;
        }
    }

    for($i = 0; $i < size($shaders); $i++) {
        string $current = $shaders[$i];
        int $has_attr = 0;
        string $attributes[] = `listAttr -shortNames $current`;
        for($j = 0; $j < size($attributes); $j++) {
            if($attributes[$j] == "fnvShaderType") {
                $has_attr = 1;
                break;
            }
        }
        if($has_attr == 0) {
            eval("addAttr -dataType \"string\" -shortName fnvShaderType " + $current);
        }
        eval("setAttr -type \"string\" " + $current + ".fnvShaderType \"" + $shaderType + "\"");
    }
}

// Opens a picker listing every blendShape target (weight alias) in the scene.
// Double-click (or Select) writes the chosen name into targetID of the last
// selected joint/shape. Decouples the choice from the auto-generated Extra
// Attributes section, where a button can't reliably sit next to the field.
// Menu entry point: resolves the target node from the current selection, then
// delegates to the per-node version below.
global proc nifTranslatorSpecifyTargetID() {
	string $sel[] = `ls -selection -type "joint" -type "shape"`;
	if(size($sel) == 0) {
		error "Select the animated joint/shape first, then pick a target.";
		return;
	}
	nifTranslatorSpecifyTargetIDFor($sel[size($sel) - 1]);
}

// Opens the blendShape-target picker and writes the chosen name into
// <target>.targetID. Shared by the menu entry and by auto-open on single-node
// NiFloatInterpolator assignment.
global proc nifTranslatorSpecifyTargetIDFor(string $target) {
	// Gather all blendShape target names (weight aliases) in the scene.
	string $names[];
	string $blendShapes[] = `ls -type "blendShape"`;
	for($b = 0; $b < size($blendShapes); $b++) {
		string $aliases[] = `aliasAttr -query $blendShapes[$b]`;
		for($a = 0; $a < size($aliases); $a += 2) {
			$names[size($names)] = $aliases[$a];
		}
	}

	if(size($names) == 0) {
		warning "No blendShape targets found in the scene; targetID left empty.";
		return;
	}

	if(`window -exists nifTargetIDPicker`) deleteUI nifTargetIDPicker;
	window -title ("Specify Target ID  ->  " + $target) -widthHeight 280 360 nifTargetIDPicker;
	columnLayout -adjustableColumn true -rowSpacing 4 -columnAttach "both" 6;
		text -label ("Writing into: " + $target + ".targetID") -align "left";
		textScrollList -numberOfRows 16 -allowMultiSelection false
			-doubleClickCommand ("nifTargetIDPickerApply(\"" + $target + "\")")
			nifTargetIDList;
		for($i = 0; $i < size($names); $i++) {
			textScrollList -edit -append $names[$i] nifTargetIDList;
		}
		rowLayout -numberOfColumns 2 -columnWidth2 134 134;
			button -label "Select" -command ("nifTargetIDPickerApply(\"" + $target + "\")");
			button -label "Cancel" -command "deleteUI nifTargetIDPicker";
		setParent ..;
	setParent ..;
	showWindow nifTargetIDPicker;
}

// Writes the picked list item into <node>.targetID (creating the attr if needed).
global proc nifTargetIDPickerApply(string $target) {
	string $picked[] = `textScrollList -query -selectItem nifTargetIDList`;
	if(size($picked) == 0) {
		warning "Pick a target from the list first.";
		return;
	}

	int $hasTargetID = 0;
	string $attrs[] = `listAttr -shortNames $target`;
	for($j = 0; $j < size($attrs); $j++) {
		if($attrs[$j] == "targetID") { $hasTargetID = 1; break; }
	}
	if($hasTargetID == 0) {
		eval("addAttr -dataType \"string\" -shortName \"targetID\" -longName \"targetID\" " + $target);
	}

	eval("setAttr -type \"string\" " + $target + "\.targetID \"" + $picked[0] + "\"");
	print ("\nSet " + $target + ".targetID = " + $picked[0] + "\n");
	deleteUI nifTargetIDPicker;
}