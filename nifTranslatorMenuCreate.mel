	nifTranslatorAddSkyrimShaderFlags("SLSF1_Recieve_Shadows", 1);
	nifTranslatorAddSkyrimShaderFlags("SLSF1_Cast_Shadows", 1);
	nifTranslatorAddSkyrimShaderFlags("SLSF1_Own_Emit", 1);
	nifTranslatorAddSkyrimShaderFlags("SLSF1_Remappable_Textures", 1);
	nifTranslatorAddSkyrimShaderFlags("SLSF1_ZBuffer_Test", 1);
	
	nifTranslatorAddSkyrimShaderFlags("SLSF2_ZBuffer_Write", 2);
	nifTranslatorAddSkyrimShaderFlags("SLSF2_Double_Sided", 2);
	nifTranslatorAddSkyrimShaderFlags("SLSF2_EnvMap_Light_Fade", 2);
}

