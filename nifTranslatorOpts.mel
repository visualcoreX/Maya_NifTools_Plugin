global proc nifTranslatorSetToExportGeometry() {
	global string $gNifExportType;

	$gNifExportType = "geometry";
}

global proc nifTranslatorSetToExportAnimation() {
	global string $gNifExportType;

	$gNifExportType = "animation";
}

// Maps the dropdown label to the exportType token read by NifTranslatorOptions.
// "geometry" / "animation" are the existing tokens; "nifanimation" is the new
// combined mode (geometry + embedded keyframe data in one .nif).
global proc nifExportModeChange(string $label) {
	global string $gNifExportType;

	if ($label == "NIF w/ Animation") {
		$gNifExportType = "nifanimation";
	} else if ($label == "KF") {
		$gNifExportType = "animation";
	} else {
		// "NIF w/o Animation"
		$gNifExportType = "geometry";
	}
}

global proc nifCycleTypeChange(string $value) {
	global string $gNifCycleType;
	$gNifCycleType = $value;
}

// Enable/disable the Animation name field based on the "use manual name" checkbox.
// When unchecked, the name is auto-derived on export, so the field is locked.
global proc nifToggleAnimNameField() {
	int $manual = `checkBox -query -value useManualAnimNameCk`;
	textField -edit -editable $manual animationNameTx;
}

// Enable the "keys to sample" field only if the current selection contains at least
// one node set to a B-spline interpolator (that's the only case where it matters).
// Checked once when the options window is built (per current Maya selection).
global proc nifUpdateKeysToSampleField() {
	int $hasSpline = 0;
	string $sel[] = `ls -selection -long`;
	for ($node in $sel) {
		// interpolatorType is a per-node string attribute; absent => default
		// NiTransformInterpolator, which ignores the sample count.
		if (`attributeExists "interpolatorType" $node`) {
			string $t = `getAttr ($node + ".interpolatorType")`;
			if ($t == "NiBSplineCompTransformInterpolator" ||
			    $t == "NiBSplineTransformInterpolator") {
				$hasSpline = 1;
				break;
			}
		}
	}
	textField -edit -editable $hasSpline numberOfKeysToSampleTx;
}

global proc int hasValidNifName(string $name) {
	if($name == "front" || $name == "side" || $name == "top" || $name == "persp" ) return 0;
	if($name == "Manipulator1" || $name == "ViewCompass" ||  $name == "CubeCompass" || $name == "groundPlane_transform") return 0;
	
	return 1;
}

// This procedure is called when the 'Open' button of the dialog is clicked.
// The procedure recieves the name of the file and it's extension
global proc int onOk(string $dirpath, string $type) {
	// Normalize separators so a browsed Windows path can't inject backslash escapes.
	$dirpath = substituteAllString($dirpath, "\\", "/");
	textField -edit -text $dirpath nifTxPath;
	return true;
}

// Reset the Game Preset dropdown back to "-- Select Game --". Called whenever the
// user manually changes any export option, since the preset no longer matches.
global proc nifResetGamePreset() {
	global string $gNifGamePreset;
	$gNifGamePreset = "-- Select Game --";
	if (`optionMenu -exists gamePresetMenu`) {
		optionMenu -edit -value "-- Select Game --" gamePresetMenu;
	}
}

// Hook attached to every manual control's change/command callback.
global proc nifOnExportOptionChanged() {
	nifResetGamePreset();
}

global proc nifApplyGamePreset(string $game) {
    // Remember the chosen preset so it can be restored when the window reopens.
    global string $gNifGamePreset;
    $gNifGamePreset = $game;

    if ($game == "Morrowind") {
        textField -edit -text "4.0.0.2" nifVersion;
        textField -edit -text "0" expUserVersionTx;
        textField -edit -text "0" expUserVersion2Tx;
        textField -edit -text "0" expPartBonesTx;
        radioButton -edit -select nifTranslatorStandardMaterialRd;
        radioButton -edit -select nifTranslatorNoTangentSpaceDataRd;
        checkBox -edit -value false expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    } else if ($game == "Oblivion") {
        textField -edit -text "20.0.0.5" nifVersion;
        textField -edit -text "11" expUserVersionTx;
        textField -edit -text "11" expUserVersion2Tx;
        textField -edit -text "20" expPartBonesTx;
        radioButton -edit -select nifTranslatorStandardMaterialRd;
        radioButton -edit -select nifTranslatorOblivionTangentSpaceDataRd;
        checkBox -edit -value false expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    } else if ($game == "Fallout 3" || $game == "Fallout New Vegas") {
        textField -edit -text "20.2.0.7" nifVersion;
        textField -edit -text "11" expUserVersionTx;
        textField -edit -text "34" expUserVersion2Tx;
        textField -edit -text "20" expPartBonesTx;
        radioButton -edit -select nifTranslatorFalloutMaterialRd;
        radioButton -edit -select nifTranslatorFalloutSkyrimTangentSpaceDataRd;
        checkBox -edit -value true expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    } else if ($game == "Skyrim") {
        textField -edit -text "20.2.0.7" nifVersion;
        textField -edit -text "11" expUserVersionTx;
        textField -edit -text "83" expUserVersion2Tx;
        textField -edit -text "20" expPartBonesTx;
        radioButton -edit -select nifTranslatorSkyrimMaterialRd;
        radioButton -edit -select nifTranslatorFalloutSkyrimTangentSpaceDataRd;
        checkBox -edit -value true expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    } else if ($game == "Skyrim SE") {
        textField -edit -text "20.2.0.7" nifVersion;
        textField -edit -text "11" expUserVersionTx;
        textField -edit -text "100" expUserVersion2Tx;
        textField -edit -text "20" expPartBonesTx;
        radioButton -edit -select nifTranslatorSkyrimMaterialRd;
        radioButton -edit -select nifTranslatorFalloutSkyrimTangentSpaceDataRd;
        checkBox -edit -value true expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    } else if ($game == "Fallout 4") {
        textField -edit -text "20.2.0.7" nifVersion;
        textField -edit -text "12" expUserVersionTx;
        textField -edit -text "130" expUserVersion2Tx;
        textField -edit -text "20" expPartBonesTx;
        radioButton -edit -select nifTranslatorFalloutMaterialRd;
        radioButton -edit -select nifTranslatorFalloutSkyrimTangentSpaceDataRd;
        checkBox -edit -value true expBsFadeNodeRootCk;
        checkBox -edit -value true expFlatenedSkeletonCk;
    } else if ($game == "Civilization IV") {
        textField -edit -text "20.0.0.4" nifVersion;
        textField -edit -text "0" expUserVersionTx;
        textField -edit -text "0" expUserVersion2Tx;
        textField -edit -text "4" expPartBonesTx;
        radioButton -edit -select nifTranslatorStandardMaterialRd;
        radioButton -edit -select nifTranslatorNoTangentSpaceDataRd;
        checkBox -edit -value false expBsFadeNodeRootCk;
        checkBox -edit -value false expFlatenedSkeletonCk;
    }
}