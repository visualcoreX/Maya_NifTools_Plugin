		button -edit -label "Deselect all misc" selectAllMiscBt;
	} else {
		nifTranslatorSelectMisc(1);
		button -edit -label "Select all misc" selectAllMiscBt;
	}
}

global proc nifTranslatorSelectEverything() {
	string $type = `button -query -label selectEverythingBt`;

	if($type == "Select everything") {
		nifTranslatorSelectMisc(0);
		nifTranslatorSelectJoints(0);
		nifTranslationSelectShapes(0);
		button -edit -label "Deselect everything" selectEverythingBt;
	} else {
		nifTranslatorSelectMisc(1);
		nifTranslationSelectShapes(1);
		nifTranslatorSelectJoints(1);
		button -edit -label "Select everything" selectEverythingBt;
	}
}

global proc nifTranslationSelectShapes(int $deselect) {
	global string $gNifExportedObjects[];
	global int $gNifExportedObjectsValues[];
	global string $gNifExportedObjectsTypes[];

	if($deselect == 1) {
		for($i = 0; $i < size($gNifExportedObjects); $i++) {
			if($gNifExportedObjectsTypes[$i] == "shape" && $gNifExportedObjectsValues[$i] == 1) {
				$gNifExportedObjectsValues[$i] = 0;
				treeView -edit -buttonTextIcon $gNifExportedObjects[$i] 1 "" overviewTreeView;	
				eval("select -deselect " + $gNifExportedObjects[$i]);
			}
		}
	} else {
		for($i = 0; $i < size($gNifExportedObjects); $i++) {
			if($gNifExportedObjectsTypes[$i] == "shape" && $gNifExportedObjectsValues[$i] == 0) {
				$gNifExportedObjectsValues[$i] = 1;
				treeView -edit -buttonTextIcon $gNifExportedObjects[$i] 1 "E" overviewTreeView;	
				eval("select -add " + $gNifExportedObjects[$i]);
			}
		}
		AdjustSelectedJoints();
	}
}

